      {
        "markdown_text": {
          "select_text_type": "body_copy_v2",
          "select_semantics_type": null,
          "markdown_text": "Fondée en 1959 par Ruth Handler, Barbie a évolué au fil des ans. Voici quelques faits sur la poupée de Barbiemedia.com*. Les entrepôts Costco et [Costco.ca](/.product.4000160795.html) offrent des jouets Barbie.",
          "color": {
            "background_gradient_style": "solid",
            "background_color": {
              "hex": "#FFFFFF"
            },
            "background_gradient_color": {
              "color1": {
                "hex": ""
              },
              "color2": {
                "hex": ""
              }
            },
            "text_color": {
              "hex": "#333333"
