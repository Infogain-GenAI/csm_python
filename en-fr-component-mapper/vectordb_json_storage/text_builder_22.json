          "text_section_content": [
            {
              "select_text_type": "body_copy_v2",
              "select_semantics_type": null,
              "text_alignment": "left",
              "enable_custom_tag_parsing": false,
              "markdown_text": "When using digital tools, consider how the tone of the message might be received. Video-conferencing, social media and email can be problematic. None of these tools allows you to communicate like you can when you are face-to-face. With the ease of a “share” or the “forward” button, your communication may travel well beyond its original recipient. Since technology tools archive all of our digital communication, it is worth the time and effort to get all of this right.—*JZ*",
              "color": {}
            }
          ]
        }
